{
  "expo": {
    "name": "Ravyn",
    "slug": "ravyn",
    "scheme": "ravyn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/af5a7704-15aa-4f1e-b35e-0adafbf6dbc0",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ravyn.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ravyn.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "af5a7704-15aa-4f1e-b35e-0adafbf6dbc0"
      }
    },
    "owner": "akarmis-organization",
    "plugins": [
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ravyn to access your photos to set a profile picture.",
          "cameraPermission": "Allow Ravyn to use your camera to take a profile picture."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "ravyn",
          "organization": "trakr"
        }
      ],
      "@sentry/react-native"
    ]
  }
}
