# Ravyn — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase project URL (found in: Supabase Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in: Supabase Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry DSN (found in: Sentry Dashboard → Project → Settings → Client Keys)
EXPO_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
